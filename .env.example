# =============================================
# Easy Park - Variables de entorno
# Copie este archivo a .env y complete los valores
# NUNCA suba .env al repositorio
# =============================================

# Servidor
SERVER_PORT=8080

# Base de datos PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/easy_park
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (mínimo 256 bits / 32 caracteres)
JWT_SECRET=cambia-este-secreto-por-uno-seguro-de-al-menos-32-chars
JWT_EXPIRATION=86400000

# Firebase
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here

# SonarQube (solo para CI/CD)
SONAR_TOKEN=your_sonar_token_here
